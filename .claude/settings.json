{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path') && [[ \"$FILE\" == *.py ]] && pyright \"$FILE\" || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
